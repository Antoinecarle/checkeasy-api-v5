# 🔑 Configuration CheckEasy API V5
# Copiez ce fichier en .env et remplissez les valeurs

# ============================================
# OPENAI CONFIGURATION (OBLIGATOIRE)
# ============================================
# Votre clé API OpenAI (commence par sk-proj-...)
# Obtenez-la sur: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-VOTRE_CLE_ICI

# Modèle OpenAI à utiliser (optionnel, défaut: gpt-5.2-2025-12-11)
# OPENAI_MODEL=gpt-5.2-2025-12-11

# ============================================
# ENVIRONNEMENT (OBLIGATOIRE)
# ============================================
# Version de l'environnement: "test" pour staging, "live" pour production
VERSION=test

# Ou utilisez ENVIRONMENT (alternative)
# ENVIRONMENT=staging

# ============================================
# RAILWAY CONFIGURATION (Optionnel - Auto-détecté)
# ============================================
# Ces variables sont automatiquement définies par Railway
# Ne les définissez que si vous testez en local

# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=checkeasy-api-production.up.railway.app
# RAILWAY_SERVICE_NAME=checkeasy-api

# ============================================
# CONFIGURATION DES PROMPTS (Optionnel)
# ============================================
# Si vous voulez surcharger les prompts depuis Railway
# Sinon, les fichiers JSON locaux seront utilisés

# PROMPTS_CONFIG_VOYAGEUR={"version":"1.0.0",...}
# PROMPTS_CONFIG_MENAGE={"version":"1.0.0",...}

# ============================================
# CONFIGURATION DES TEMPLATES DE PIÈCES (Optionnel)
# ============================================
# Si vous voulez surcharger les templates depuis Railway
# Sinon, les fichiers JSON locaux seront utilisés

# ROOM_TEMPLATES_CONFIG_VOYAGEUR={"room_types":{...}}
# ROOM_TEMPLATES_CONFIG_MENAGE={"room_types":{...}}

# ============================================
# NOTES
# ============================================
# 1. Ne commitez JAMAIS ce fichier avec vos vraies clés !
# 2. Le fichier .env est dans .gitignore pour votre sécurité
# 3. Pour la production, définissez ces variables dans Railway
# 4. Pour le développement local, créez un fichier .env à partir de ce template

